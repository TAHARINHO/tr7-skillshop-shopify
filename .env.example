# TR7 Shop Builder — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs

NODE_ENV=production
PORT=3700

# Optionnel: corsOrigins (séparés par des virgules)
# Laissez vide pour autoriser toutes les origines
CORS_ORIGINS=https://taharinho.github.io,https://votre-domaine.com

# Optionnel: si vous proxiez les clés API côté serveur
# (sinon les clés restent dans le localStorage du client)
# ANTHROPIC_API_KEY=sk-ant-api03-...
# OPENAI_API_KEY=sk-proj-...
